{
  "name": "@jorisjonkers-dev/vue-web-commons",
  "type": "module",
  "version": "0.5.0",
  "private": false,
  "packageManager": "npm@10.9.8",
  "description": "Framework-neutral Vue 3 commons for Joris Jonkers web applications.",
  "license": "LicenseRef-JorisJonkers-Proprietary-1.0",
  "homepage": "https://github.com/JorisJonkers-dev/vue-web-commons#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/JorisJonkers-dev/vue-web-commons.git"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./api-runtime": {
      "types": "./dist/api-runtime/index.d.ts",
      "import": "./dist/api-runtime/index.js"
    },
    "./config": {
      "types": "./dist/config/index.d.ts",
      "import": "./dist/config/index.js"
    },
    "./eslint": {
      "types": "./dist/config/eslint.d.ts",
      "import": "./dist/config/eslint.js"
    },
    "./nginx": {
      "types": "./dist/nginx/index.d.ts",
      "import": "./dist/nginx/index.js"
    },
    "./prettier": "./prettier.config.mjs",
    "./style.css": {
      "types": "./dist/style.css.d.ts",
      "default": "./dist/style.css"
    },
    "./theme.css": {
      "types": "./dist/theme.css.d.ts",
      "default": "./dist/theme.css"
    },
    "./tsconfig/base": "./tsconfig.base.json",
    "./package.json": "./package.json"
  },
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "LICENSE",
    "README.md",
    "dist",
    "prettier.config.mjs",
    "tsconfig.base.json"
  ],
  "publishConfig": {
    "registry": "https://npm.pkg.github.com",
    "access": "public"
  },
  "scripts": {
    "clean": "rm -rf dist",
    "typecheck": "vue-tsc --noEmit",
    "lint": "eslint . --max-warnings 0",
    "format:check": "prettier --check .",
    "format": "prettier --write .",
    "test": "vitest run --coverage",
    "coverage": "vitest run --coverage",
    "test:watch": "vitest",
    "build": "npm run clean && vite build && node scripts/normalize-dts.mjs && cp src/style.css.d.ts dist/style.css.d.ts && cp src/theme.css dist/theme.css && cp src/theme.css.d.ts dist/theme.css.d.ts",
    "package:check": "npm run build && npm pack --dry-run && node scripts/check-package.mjs",
    "fixture:check": "npm run build && vue-tsc -p tsconfig.fixture.json --noEmit"
  },
  "peerDependencies": {
    "@antfu/eslint-config": "^9.0.0",
    "@grafana/faro-web-sdk": "^2.8.2",
    "@grafana/faro-web-tracing": "^2.8.2",
    "@playwright/test": "^1.0.0",
    "@vitejs/plugin-vue": "^6.0.0",
    "dependency-cruiser": "^17.0.0",
    "eslint": "^10.4.1",
    "pinia": "^3.0.4",
    "prettier": "^3.9.4",
    "typescript": "^6.0.3",
    "vite": "^8.0.0",
    "vitest": "^4.0.0",
    "vue": "^3.5.35",
    "vue-router": "^5.1.0"
  },
  "peerDependenciesMeta": {
    "@antfu/eslint-config": {
      "optional": true
    },
    "@playwright/test": {
      "optional": true
    },
    "@vitejs/plugin-vue": {
      "optional": true
    },
    "dependency-cruiser": {
      "optional": true
    },
    "eslint": {
      "optional": true
    },
    "prettier": {
      "optional": true
    },
    "typescript": {
      "optional": true
    },
    "vite": {
      "optional": true
    },
    "vitest": {
      "optional": true
    }
  },
  "devDependencies": {
    "@antfu/eslint-config": "^9.0.0",
    "@vitejs/plugin-vue": "^6.0.7",
    "@vitest/coverage-v8": "^4.1.8",
    "@vue/test-utils": "^2.4.11",
    "eslint": "^10.4.1",
    "jiti": "^2.7.0",
    "jsdom": "^29.1.1",
    "prettier": "^3.9.4",
    "typescript": "^6.0.3",
    "vite": "^8.0.16",
    "vite-plugin-dts": "^5.0.2",
    "vitest": "^4.1.8",
    "vue-tsc": "^3.3.4"
  },
  "overrides": {
    "glob": "^13.0.6",
    "undici": "^7.28.0"
  }
}
